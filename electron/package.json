{
  "name": "idepGolem",
  "version": "1.0.0",
  "description": "Desktop App for iDEP",
  "private": true,
  "main": "main.js",
  "author": {
    "name": "Xijin Ge",
    "email": "gexijin@gmail.com"
  },  
  "repository": {
    "type": "git",
    "url": "https://github.com/dan-burk/idepGolem.git"
  },  
  "license": "CC-BY-NC-3.0",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish=never"
  },
  "dependencies": {
    "fs-extra": "^11.2.0",
    "tar": "^6.2.1"
  },
  "devDependencies": {
    "electron": "39.8.4",
    "electron-builder": "^26.8.2",
    "@electron/notarize": "^2.5.0"
  },
  "build": {
    "appId": "com.idepgolem.app",           
    "productName": "iDEP",            
    "asar": false,                         
    "files": [
      "main.js",
      "bootstrap.R",
      "splash.html",
      "renderer/**",
      "preload/**",
      "package.json",
      "node_modules/**",
      "data/**",
      "runtime/**",
      "app/**"
    ],
    "extraResources": [
      { "from": "resources", "to": "." },
      { "from": "runtime", "to": "runtime" },
      { "from": "app", "to": "app" }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "mac": {
      "category": "public.app-category.education",
      "target": [ "zip" ],
      "icon": "build/icon-mac.png",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",   
      "notarize": false,
      "signIgnore": [
        ".*R\\.framework/Resources/library/.*/help(/.*)?",
        ".*R\\.framework/Resources/library/.*/doc(/.*)?",
        ".*R\\.framework/Resources/library/.*/html(/.*)?",
        ".*R\\.framework/Resources/library/.*/examples(/.*)?",
        ".*R\\.framework/Resources/library/.*/R(/.*)?",
        ".*R\\.framework/Resources/library/.*/data(/.*)?"
      ]      
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Science",
      "artifactName": "idep-${version}-linux-${arch}.${ext}",
      "maintainer": "Xijin Ge <gexijin@gmail.com>"
    },
    
    "nsis": {
      "oneClick": true
    }
  }
}