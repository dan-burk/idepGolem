# Auto-detect text files and normalize line endings to LF
* text=auto

# Ensure shell scripts always use LF line endings
*.sh text eol=lf

# R files
*.R text eol=lf
*.Rmd text eol=lf
*.Rproj text eol=lf

# Web files
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
